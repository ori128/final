<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <TextView
        android:id="@+id/tv_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="24dp"
        android:text="היסטוריית פגישות"
        android:textColor="#1F2937"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_history_title">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/sv_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:iconifiedByDefault="false"
            app:queryBackground="@android:color/transparent"
            app:queryHint="חפש לפי כותרת או מיקום..." />
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cv_search" />

    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cv_search">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_empty"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@android:color/transparent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/sleep" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="אין לך פגישות היסטוריות..."
            android:textAlignment="center"
            android:textColor="#6B7280"
            android:textSize="16sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_bottom_nav"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:layoutDirection="ltr">

            <ImageButton android:id="@+id/nav_upcoming" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_today" app:tint="#6B7280" />
            <View android:layout_width="8dp" android:layout_height="match_parent" />

            <ImageButton android:id="@+id/nav_history" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_recent_history" app:tint="#3B82F6" />
            <View android:layout_width="8dp" android:layout_height="match_parent" />

            <RelativeLayout android:layout_width="48dp" android:layout_height="48dp">
                <ImageButton android:id="@+id/nav_notifications" android:layout_width="match_parent" android:layout_height="match_parent" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_popup_reminder" app:tint="#6B7280" />
                <com.google.android.material.card.MaterialCardView android:id="@+id/cv_notification_badge" android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:layout_alignParentTop="true" android:layout_marginTop="6dp" android:layout_marginEnd="6dp" android:visibility="gone" app:cardBackgroundColor="#EF4444" app:cardCornerRadius="8dp" app:strokeWidth="0dp">
                    <TextView android:id="@+id/tv_notification_badge_count" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:includeFontPadding="false" android:text="1" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>
            <View android:layout_width="8dp" android:layout_height="match_parent" />

            <ImageButton android:id="@+id/nav_progress" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#6B7280" />
            <View android:layout_width="8dp" android:layout_height="match_parent" />

            <ImageButton android:id="@+id/nav_add" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_input_add" app:tint="#6B7280" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>